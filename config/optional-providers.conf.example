# BEGIN OPTIONAL PROVIDERS

# ---------------------------------------------------------------------------
# CallMeBot Telegram
# ---------------------------------------------------------------------------

# Enable Telegram by adding "callmebot-telegram" to NOTIFY_PROVIDERS.
#
# First authorize CallMeBot by sending /start to:
#
#   @CallMeBot_txtbot
#
# Multiple recipients may be separated with "|".
#
# CALLMEBOT_TELEGRAM_USERS="@myusername"

# ---------------------------------------------------------------------------
# Authenticated SMTP
# ---------------------------------------------------------------------------

# Enable SMTP by adding "smtp" to NOTIFY_PROVIDERS.
#
# Recommended authenticated configuration:
#
#   SMTP_PORT="587"
#   SMTP_SECURITY="starttls"
#
# SMTP_HOST="mail.example.com"
# SMTP_PORT="587"
# SMTP_SECURITY="starttls"
#
# SMTP_USERNAME="sentinel@example.com"
# SMTP_PASSWORD="CHANGE_ME"
#
# Envelope sender used by SMTP MAIL FROM.
# SMTP_FROM_ADDRESS="sentinel@example.com"
#
# Human-readable From header.
# SMTP_FROM="EMPRETEL Sentinel <sentinel@example.com>"
#
# Multiple recipients may be separated with commas.
# SMTP_TO="admin@example.com"
#
# SMTP_CONNECT_TIMEOUT="5"
# SMTP_TIMEOUT="20"
# SMTP_LOW_SPEED_LIMIT="1"
# SMTP_LOW_SPEED_TIME="10"
#
# Set to 1 only when intentionally accepting an untrusted TLS certificate.
# SMTP_TLS_INSECURE="0"

# END OPTIONAL PROVIDERS
