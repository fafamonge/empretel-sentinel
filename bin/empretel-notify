#!/usr/bin/env bash

set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"

BASE_DIR="$(
    cd "$(dirname "${SCRIPT_PATH}")/.." &&
    pwd
)"

# shellcheck disable=SC1091
source "${BASE_DIR}/lib/common.sh"

usage() {
    cat <<'USAGE'
Usage:
  empretel-notify <level> <message>

Levels:
  info
  success
  warning
  critical

Example:
  empretel-notify success "Service recovered successfully."
USAGE
}

if [ "$#" -lt 2 ]; then
    usage >&2
    exit 2
fi

LEVEL="$1"
shift

MESSAGE="$*"

case "${LEVEL}" in
    info)
        ICON="ℹ️"
        ;;
    success)
        ICON="✅"
        ;;
    warning)
        ICON="⚠️"
        ;;
    critical)
        ICON="🚨"
        ;;
    *)
        sentinel_error "Unsupported notification level: ${LEVEL}"
        usage >&2
        exit 2
        ;;
esac

sentinel_load_config

PROVIDER_FILE="${BASE_DIR}/providers/${NOTIFY_PROVIDER}.sh"

if [ ! -r "${PROVIDER_FILE}" ]; then
    sentinel_error "Notification provider not found: ${PROVIDER_FILE}"
    exit 1
fi

# shellcheck disable=SC1090
source "${PROVIDER_FILE}"

EVENT_TIMESTAMP="$(sentinel_timestamp)"
EVENT_ID="$(sentinel_event_id)"
NODE_DISPLAY="${NODE_NAME^^}"
LEVEL_DISPLAY="${LEVEL^^}"

FULL_MESSAGE="${ICON} *${LEVEL_DISPLAY}*

Node: ${NODE_DISPLAY}
Timestamp: ${EVENT_TIMESTAMP}
Event ID: ${EVENT_ID}

${MESSAGE}"

case "${NOTIFY_PROVIDER}" in
    callmebot)
        if ! RESPONSE="$(callmebot_send "${FULL_MESSAGE}")"; then
            sentinel_log \
                "notify" \
                "Provider=${NOTIFY_PROVIDER}; level=${LEVEL}; result=failed; message=${MESSAGE}"

            exit 1
        fi
        ;;
    *)
        sentinel_error "Unsupported notification provider: ${NOTIFY_PROVIDER}"
        exit 1
        ;;
esac

sentinel_log \
    "notify" \
    "Provider=${NOTIFY_PROVIDER}; level=${LEVEL}; result=sent; message=${MESSAGE}"

printf '%s\n' "${RESPONSE}"
